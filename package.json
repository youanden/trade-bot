{
  "name": "trade-bot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && wrangler deploy --dry-run --outdir dist",
    "build:ui": "vite build",
    "deploy": "vite build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply trade-bot-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply trade-bot-db --remote",
    "db:studio": "drizzle-kit studio",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.64.0",
    "ai": "^6.0.134",
    "ai-gateway-provider": "^3.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.7.0",
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.0",
    "@cloudflare/workers-types": "^4.20250214.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "drizzle-kit": "^0.30.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "wrangler": "^4.0.0"
  }
}
